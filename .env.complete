# ============================================================================
# ANTHROPIC API Configuration
# ============================================================================
CLAUDE_API_KEY=sk-your-anthropic-api-key-here
MODEL=claude-3-5-sonnet-20241022
API_TIMEOUT=30

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ============================================================================
# FASTAPI SERVER CONFIGURATION
# ============================================================================
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_RELOAD=true
FASTAPI_WORKERS=4

# ============================================================================
# STREAMLIT UI CONFIGURATION
# ============================================================================
STREAMLIT_PORT=8501
STREAMLIT_THEME=light
STREAMLIT_MAX_UPLOAD_SIZE=200  # MB

# ============================================================================
# DATABASE CONFIGURATION (for future persistence)
# ============================================================================
DATABASE_URL=sqlite:///./loan_approval.db
# For production: postgresql://user:password@localhost/loan_db
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5

# ============================================================================
# REDIS CACHE CONFIGURATION (for distributed caching)
# ============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_EXPIRATION=3600  # seconds

# ============================================================================
# LANGGRAPH ORCHESTRATION SETTINGS
# ============================================================================
LANGGRAPH_DEBUG=true
MAX_AGENTS_PARALLEL=4
AGENT_TIMEOUT=45  # seconds

# ============================================================================
# MCP SERVER CONFIGURATION
# ============================================================================
MCP_SERVER_PORT=8502
MCP_ENABLE_DOCUMENT_SERVER=true
MCP_ENABLE_CREDIT_SERVER=true
MCP_ENABLE_COMPLIANCE_SERVER=true

# ============================================================================
# SECURITY SETTINGS
# ============================================================================
SECRET_KEY=your-secret-key-for-jwt-tokens
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
CORS_ORIGINS=http://localhost:3000,http://localhost:8501,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
LOG_FILE_PATH=./logs/app.log
LOG_FORMAT=json
SENTRY_DSN=  # Optional: Sentry error tracking

# ============================================================================
# DECISION THRESHOLDS
# ============================================================================
MIN_CREDIT_SCORE=600
MAX_DEBT_TO_INCOME=0.43
MIN_INCOME_VERIFICATION_CONFIDENCE=0.80
MIN_EMPLOYMENT_VERIFICATION_CONFIDENCE=0.70
LOAN_AMOUNT_MIN=10000
LOAN_AMOUNT_MAX=1000000

# ============================================================================
# APPROVAL DECISION SCORES
# ============================================================================
APPROVAL_THRESHOLD=75
REJECTION_THRESHOLD=40
MANUAL_REVIEW_MIN=40
MANUAL_REVIEW_MAX=75

# ============================================================================
# EXTERNAL INTEGRATIONS (Future)
# ============================================================================
CREDIT_BUREAU_API_KEY=  # Equifax, Experian, TransUnion
BANKING_SYSTEM_API_URL=
KYC_PROVIDER_API_KEY=
DOCUMENT_VERIFICATION_SERVICE_URL=

# ============================================================================
# NOTIFICATION SETTINGS (Future)
# ============================================================================
WEBHOOK_ENABLED=false
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_TIMEOUT=10

# Email notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
NOTIFICATION_EMAIL_FROM=noreply@loanapproval.com

# Slack notifications
SLACK_WEBHOOK_URL=
SLACK_ENABLED=false

# ============================================================================
# CLAUDE CODE / AGENT SDK SETTINGS
# ============================================================================
CLAUDE_CODE_ENABLED=true
AGENT_SDK_VERSION=latest
ENABLE_STREAMING=true

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================
SAMPLE_DATA_PATH=./sample_data/
MOCK_AGENTS=false
SKIP_VERIFICATION=false
